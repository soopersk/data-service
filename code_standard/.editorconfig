# EditorConfig — Consistent coding styles across editors & IDEs
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.java]
indent_size = 2
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.{json,xml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.properties]
indent_size = 2

[Makefile]
indent_style = tab

[Dockerfile*]
indent_size = 2

[*.sh]
indent_size = 2
