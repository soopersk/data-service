<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
  "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Checkstyle Configuration (Merged)
    ─────────────────────────────────
    Formatting is handled by google-java-format (fmt-maven-plugin).
    This config focuses ONLY on rules the formatter cannot enforce:
    naming, complexity, code quality, Javadoc, and anti-patterns.

    Rules deliberately EXCLUDED (handled by google-java-format):
      - LineLength (formatter enforces 100)
      - ImportOrder (formatter sorts imports)
      - LeftCurly / RightCurly (formatter places braces)
      - WhitespaceAfter / WhitespaceAround (formatter handles spacing)
      - Indentation (formatter handles indentation)

    Rules deliberately EXCLUDED (too noisy / low value):
      - FinalLocalVariable (forces `final` everywhere, reduces readability)
-->
<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <property name="severity" value="error"/>
  <property name="fileExtensions" value="java"/>

  <!-- Skip generated files before parsing (faster than suppression matching) -->
  <module name="BeforeExecutionExclusionFileFilter">
    <property name="fileNamePattern" value="module\-info\.java|.*Generated.*"/>
  </module>

  <!-- Suppressions for tests, DTOs, config classes -->
  <module name="SuppressionFilter">
    <property name="file" value="${config_loc}/suppressions.xml"/>
    <property name="optional" value="true"/>
  </module>

  <!-- No trailing whitespace -->
  <module name="RegexpSingleline">
    <property name="format" value="\s+$"/>
    <property name="message" value="Line has trailing whitespace."/>
  </module>

  <!-- File length: flag files over 1000 lines (suppressed for tests) -->
  <module name="FileLength">
    <property name="max" value="1000"/>
    <property name="fileExtensions" value="java"/>
  </module>

  <!-- Newline at end of file (POSIX standard) -->
  <module name="NewlineAtEndOfFile"/>

  <module name="TreeWalker">

    <!-- ━━━ Naming Conventions ━━━ -->
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
    </module>
    <module name="TypeName">
      <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
    </module>
    <module name="MethodName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>
    <module name="MemberName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>
    <module name="ParameterName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>
    <module name="LocalVariableName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>
    <module name="ConstantName">
      <!-- UPPER_SNAKE_CASE, with exception for SLF4J loggers (log, logger) -->
      <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$|^log(ger)?$"/>
    </module>
    <module name="AbbreviationAsWordInName">
      <!-- Prevents HTTPXMLParser, forces HttpXmlParser -->
      <property name="allowedAbbreviationLength" value="2"/>
      <property name="ignoreFinal" value="false"/>
    </module>

    <!-- ━━━ Import Rules ━━━ -->
    <!-- Note: ImportOrder is NOT included — google-java-format handles ordering -->
    <module name="AvoidStarImport"/>
    <module name="RedundantImport"/>
    <module name="UnusedImports"/>
    <module name="IllegalImport">
      <property name="illegalPkgs" value="sun"/>
    </module>

    <!-- ━━━ Braces ━━━ -->
    <!-- google-java-format doesn't add missing braces, only reformats existing ones -->
    <module name="NeedBraces"/>

    <!-- ━━━ Code Quality ━━━ -->
    <module name="EqualsHashCode"/>
    <module name="MissingSwitchDefault"/>
    <module name="DefaultComesLast"/>
    <module name="FallThrough"/>
    <module name="SimplifyBooleanExpression"/>
    <module name="SimplifyBooleanReturn"/>
    <module name="StringLiteralEquality"/>
    <module name="MultipleVariableDeclarations"/>
    <module name="OneStatementPerLine"/>
    <module name="ModifiedControlVariable"/>
    <module name="InnerAssignment"/>
    <module name="CovariantEquals"/>
    <module name="NoFinalizer"/>
    <module name="SuperClone"/>
    <module name="SuperFinalize"/>
    <module name="AvoidNestedBlocks"/>
    <module name="IllegalCatch">
      <property name="illegalClassNames" value="java.lang.Throwable, java.lang.RuntimeException"/>
    </module>

    <!-- ━━━ Spring-Specific: No System.out ━━━ -->
    <module name="RegexpSinglelineJava">
      <property name="format" value="System\.(out|err)\.print(ln)?"/>
      <property name="message" value="Use SLF4J logger instead of System.out/err. See LoggingAndMetricsReference.java."/>
      <property name="ignoreComments" value="true"/>
    </module>

    <!-- ━━━ Complexity ━━━ -->
    <module name="CyclomaticComplexity">
      <property name="max" value="12"/>
    </module>
    <module name="NPathComplexity">
      <property name="max" value="50"/>
    </module>
    <module name="MethodLength">
      <property name="max" value="60"/>
    </module>
    <module name="ParameterNumber">
      <property name="max" value="5"/>
      <property name="ignoreOverriddenMethods" value="true"/>
    </module>
    <module name="BooleanExpressionComplexity">
      <property name="max" value="4"/>
    </module>

    <!-- ━━━ Javadoc (public API) ━━━ -->
    <module name="MissingJavadocType">
      <property name="scope" value="public"/>
      <property name="excludeScope" value="nothing"/>
      <property name="tokens" value="CLASS_DEF, INTERFACE_DEF, ENUM_DEF"/>
    </module>
    <module name="MissingJavadocMethod">
      <property name="scope" value="public"/>
      <property name="allowMissingPropertyJavadoc" value="true"/>
      <property name="minLineCount" value="5"/>
      <property name="tokens" value="METHOD_DEF, ANNOTATION_FIELD_DEF"/>
    </module>
    <module name="JavadocMethod">
      <property name="accessModifiers" value="public"/>
    </module>

    <!-- ━━━ Annotation Best Practices ━━━ -->
    <module name="MissingOverride"/>
    <module name="MissingDeprecated"/>

    <!-- Allow suppressing checks via @SuppressWarnings("checkstyle:RuleName") -->
    <module name="SuppressWarningsHolder"/>
  </module>

  <module name="SuppressWarningsFilter"/>
</module>
