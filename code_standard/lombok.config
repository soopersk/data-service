# ━━━ Lombok Configuration ━━━
# Applied to all classes in this directory and below.
# See: https://projectlombok.org/features/configuration

# Flag any usage of @Getter/@Setter on fields (prefer class-level)
lombok.accessors.chain = true

# Ensure @ToString never prints sensitive fields by default
lombok.toString.callSuper = call

# Copy annotations to generated methods (needed for @NonNull, validation, Jackson)
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Value
lombok.copyableAnnotations += com.fasterxml.jackson.annotation.JsonProperty

# Warn if using experimental features
lombok.experimental.flagUsage = warning

# Ban @val — use explicit types for readability
lombok.val.flagUsage = error

# Ban @var — use explicit types for readability
lombok.var.flagUsage = error

# Ban @SneakyThrows — handle exceptions explicitly
lombok.sneakyThrows.flagUsage = error

# Ban @UtilityClass — write utility classes explicitly for clarity
lombok.utilityClass.flagUsage = warning

# Add @Generated annotation so tools (JaCoCo, SonarQube) can skip Lombok code
lombok.addLombokGeneratedAnnotation = true
