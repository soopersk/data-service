-        } else {
-            nextDate = lastStartCet.toLocalDate().plusDays(1);
-        }
-
-        ZonedDateTime nextStart = ZonedDateTime.of(nextDate, estimatedStartTimeCet, CET_ZONE);
-        return nextStart.toInstant();
-    }
