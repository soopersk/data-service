-            .orElseThrow(() -> new RunNotFoundException(runId));
-        
-        if (!run.getTenantId().equals(tenantId)) {
-            throw new TenantAccessDeniedException(tenantId, runId);
-        }
-        
-        return toRunDetailResponse(run);
-    }
