-    health:
-      show-details: when_authorized
-      probes:
-        enabled: true              # Kubernetes liveness/readiness
-    loggers:
-      enabled: true                # Runtime log level changes via REST
-  health:
-    livenessstate:
-      enabled: true
-    readinessstate:
-      enabled: true
-  metrics:
-    tags:
-      application: ${spring.application.name}
-    distribution:
-      # Publish percentile histograms for these meters (Prometheus native histograms)
-      percentiles-histogram:
-        http.server.requests: true
-        http.client.requests: true
-      # Also publish computed percentiles (for non-histogram backends)
-      percentiles:
-        http.server.requests: 0.5,0.90,0.95,0.99
-        http.client.requests: 0.5,0.90,0.95,0.99
-      # SLA buckets (ms) for service-level tracking
-      slo:
-        http.server.requests: 50ms,100ms,250ms,500ms,1s,3s,5s
-    enable:
-      jvm: true
-      process: true
-      system: true
-      tomcat: true
-      hikaricp: true
-      http: true
-  # Observation config (tracing + metrics unified)
-  observations:
-    http:
-      server:
-        requests:
-          name: http.server.requests
-  tracing:
-    sampling:
-      probability: 1.0            # Sample 100% locally; reduce in prod (e.g., 0.1)
-
-# ━━━ Logging ━━━
