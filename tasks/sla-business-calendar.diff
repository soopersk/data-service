-logging:
-  level:
-    root: INFO
-    com.example.myservice: INFO
-    # Uncomment for debugging specific layers:
-    # com.example.myservice.controller: DEBUG
-    # com.example.myservice.service: DEBUG
-    # com.example.myservice.repository: DEBUG
-    # org.hibernate.SQL: DEBUG
-    # org.hibernate.type.descriptor.sql.BasicBinder: TRACE
-
-# ━━━ Custom: Request Logging ━━━
-app:
