-            return;
-        }
-
-        if (!"RUNNING".equals(run.getStatus())) {
-            log.debug("Run {} not in RUNNING status, skipping SLA monitoring", run.getRunId());
-            return;
-        }
-
-        try {
-            // Calculate score (SLA deadline as epoch millis)
