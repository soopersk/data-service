-        String runId
-        String calculatorId
-        String tenantId
-        String frequency
-        LocalDate reportingDate
-        RunStatus status
-        Instant startTime
-        Instant endTime
-        long durationMs
-        Instant slaTime
-        boolean slaBreached
-        String slaBreachReason
-    }
